# =============================================================================
# ADR AI Server - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# Required variables must be set, optional variables have defaults shown

# =============================================================================
# REQUIRED - OpenAI Configuration
# =============================================================================
OPENAI_API_KEY=sk-your-openai-key

# =============================================================================
# REQUIRED - AWS S3 / LocalStack Configuration
# =============================================================================
# For local development with LocalStack, use test credentials
# For production, use real AWS credentials and remove AWS_ENDPOINT_URL
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=adr-bucket
S3_BUCKET_REGION=us-east-1
# LocalStack endpoint (remove for production AWS)
AWS_ENDPOINT_URL=http://localstack:4566

# =============================================================================
# REQUIRED - Google OAuth 2.0 Configuration
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
SECRET_KEY=your-random-secret-key-for-jwt-signing
# Generate a random secret key: openssl rand -hex 32
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Database Configuration
# =============================================================================
# Default shown is for Docker Compose setup
# Adjust for your local PostgreSQL if running outside Docker
DATABASE_URL=postgresql+asyncpg://adr_user:adr_password@postgres:5432/adr_db

# =============================================================================
# ChromaDB Configuration
# =============================================================================
# When running locally (outside Docker): CHROMADB_HOST=localhost CHROMADB_PORT=8001
# When running in Docker: CHROMADB_HOST=chromadb CHROMADB_PORT=8000 (defaults)
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# =============================================================================
# OPTIONAL - LangSmith Configuration (for observability)
# =============================================================================
# Set LANGCHAIN_TRACING_V2=true to enable tracing
LANGCHAIN_TRACING_V2=
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=adr-ai

# =============================================================================
# OPTIONAL - LLM Configuration
# =============================================================================
# Model name for query generation and response
LLM_MODEL_NAME=gpt-4.1-nano
LLM_TEMPERATURE=0.1

# Model name for metadata and intent extraction
EXTRACTION_MODEL_NAME=gpt-4.1-nano
EXTRACTION_TEMPERATURE=0.0

# =============================================================================
# OPTIONAL - Retrieval Configuration
# =============================================================================
# Number of documents to retrieve in final results
RETRIEVAL_K=5
# Search type for retrieval (similarity, mmr, etc.)
RETRIEVAL_SEARCH_TYPE=similarity
# Enable true hybrid search (vector + BM25 + metadata filtering)
HYBRID_SEARCH_ENABLED=true
# Number of documents to retrieve from BM25 search
BM25_K=10
# Number of documents to retrieve from vector search
VECTOR_K=10
# Reciprocal Rank Fusion parameter (typical: 60)
RRF_K=60
# Max documents to return for list queries
LIST_QUERY_LIMIT=50

# =============================================================================
# OPTIONAL - Text Splitting Configuration
# =============================================================================
# Character size for document chunks
CHUNK_SIZE=1000
# Character overlap between chunks
CHUNK_OVERLAP=200

# =============================================================================
# OPTIONAL - Conversation History Configuration
# =============================================================================
# Max messages to include in prompt
CONVERSATION_HISTORY_LIMIT=10
# Max characters per message in prompt
MESSAGE_TRUNCATE_LENGTH=500
# Max recent messages for query validation
MAX_RECENT_MESSAGES=4
# Max characters for message preview in validation
MESSAGE_PREVIEW_LENGTH=200
